# ─────────────────────────────────────────────────────
# SA ERP – Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────

# ── Appwrite (Auth + Database) ──────────────────────
# Required for production. When blank, the app uses mock data.
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=
VITE_APPWRITE_DATABASE_ID=sa_erp_db

# Server-side only – used by scripts/setup-appwrite.js
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=sa_erp_db

# ── Firebase (Push Notifications) ───────────────────
# Optional. When blank, push notifications are disabled.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# ── App Config ──────────────────────────────────────
VITE_ROUTER_MODE=hash
