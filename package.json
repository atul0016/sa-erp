{
  "name": "sa-erp",
  "version": "1.0.0",
  "description": "Next-Generation On-Premise ERP System for Indian Manufacturing, Trading & Services",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:main\"",
    "web:dev": "cross-env VITE_WEBAPP=true VITE_ROUTER_MODE=hash vite",
    "dev:main": "npm run compile:main && cross-env NODE_ENV=development electronmon .",
    "compile:main": "npm run compile:preload && esbuild src/main/main.ts --bundle --platform=node --outfile=dist/main/main.js --external:electron --external:better-sqlite3 --sourcemap",
    "compile:preload": "esbuild src/main/preload.ts --bundle --platform=node --outfile=dist/main/preload.js --external:electron --sourcemap",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "web:build": "cross-env VITE_WEBAPP=true VITE_ROUTER_MODE=hash vite build",
    "web:preview": "cross-env VITE_WEBAPP=true VITE_ROUTER_MODE=hash vite preview --port 4173",
    "build:main": "tsc -p tsconfig.main.json && esbuild src/main/main.ts --bundle --platform=node --outfile=dist/main/main.js --external:electron --external:better-sqlite3",
    "build:renderer": "vite build",
    "start": "electron .",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest",
    "migrate": "tsx src/main/database/migrate.ts",
    "seed": "tsx src/main/database/seed.ts",
    "setup:appwrite": "node --env-file=.env scripts/setup-appwrite.js"
  },
  "keywords": [
    "erp",
    "indian-gst",
    "manufacturing",
    "accounting",
    "inventory",
    "electron"
  ],
  "author": "Enterprise Solutions",
  "license": "MIT",
  "dependencies": {
    "appwrite": "^24.1.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "date-fns": "^3.6.0",
    "electron-store": "^8.2.0",
    "exceljs": "^4.4.0",
    "firebase": "^12.11.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "lucide-react": "^0.562.0",
    "pdfkit": "^0.15.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@headlessui/react": "^2.0.4",
    "@heroicons/react": "^2.1.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.9",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/lodash": "^4.17.4",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^30.0.8",
    "electron-builder": "^24.13.3",
    "electronmon": "^2.0.4",
    "esbuild": "^0.21.4",
    "eslint": "^8.57.0",
    "node-appwrite": "^23.1.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7",
    "tailwindcss": "^3.4.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.0",
    "wait-on": "^9.0.3"
  }
}
