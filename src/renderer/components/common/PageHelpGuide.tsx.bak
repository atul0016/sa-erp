    subtitle: 'Input Tax Credit reconciliation',
    steps: [
      { icon: '📤', title: 'Import GSTR-2A', desc: 'Upload GSTR-2A data from the portal' },
      { icon: '🔄', title: 'Run Recon', desc: 'Click "Run Reconciliation" to compare claimed vs available ITC' },
      { icon: '🔍', title: 'Review', desc: 'Check matched, excess, and unavailable ITC' },
      { icon: '📤', title: 'Export', desc: 'Export report for audit trail' },
    ],
