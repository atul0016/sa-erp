  '/gst/hsn': {
    title: 'HSN Summary',
    subtitle: 'HSN/SAC-wise summary for GSTR-1',
    steps: [
      { icon: '📊', title: 'View Summary', desc: 'See taxable value, CGST, SGST, IGST per HSN code' },
      { icon: '📈', title: 'Analytics', desc: 'View top HSN codes by value and quantity' },
      { icon: '📥', title: 'Download', desc: 'Download in GSTR-1 format for portal upload' },
