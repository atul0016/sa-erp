// Alias routes to canonical paths
const ROUTE_ALIASES: Record<string, string> = {
  '/finance': '/finance/accounts',
  '/inventory': '/inventory/items',
  '/sales': '/sales/invoices',
  '/purchase': '/purchase/orders',
  '/manufacturing': '/manufacturing/production',
  '/hrm': '/hrm/employees',
  '/gst': '/gst/e-invoice',
  '/reports': '/reports/financial',
  '/settings/company': '/settings',
  '/settings/users': '/settings',
  '/settings/roles': '/settings',
  '/settings/master': '/settings',
};

export default function PageHelpGuide() {
  const [isOpen, setIsOpen] = useState(false);
  const [activeStep, setActiveStep] = useState(0);
  const [animating, setAnimating] = useState(false);
  const location = useLocation();

  const route = location.pathname;
  const canonicalRoute = ROUTE_ALIASES[route] || route;
  const help = PAGE_HELP[canonicalRoute];

  // Reset when page changes
  useEffect(() => {
    setIsOpen(false);
    setActiveStep(0);
  }, [route]);

  // Auto-advance animation
  useEffect(() => {
    if (!isOpen || !help) return;
    setAnimating(true);
    const t = setTimeout(() => setAnimating(false), 400);
    return () => clearTimeout(t);
  }, [activeStep, isOpen]);

  if (!help) return null;

  const nextStep = () => setActiveStep(s => Math.min(s + 1, help.steps.length - 1));
  const prevStep = () => setActiveStep(s => Math.max(s - 1, 0));

  return (
    <>
      {/* "?" Button — fixed bottom-left, away from page action buttons and chatbot */}
      <button
        onClick={() => setIsOpen(true)}
        className="fixed bottom-4 left-4 z-[9998] w-9 h-9 rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 text-white shadow-lg hover:shadow-xl hover:scale-110 transition-all duration-200 flex items-center justify-center text-sm font-bold lg:left-[17rem]"
        title="Page Help Guide"
      >
        ?
      </button>

      {/* Overlay */}
      {isOpen && (
        <div
          className="fixed inset-0 z-[9998] bg-black/40 backdrop-blur-[2px] flex items-start justify-center pt-20 sm:pt-24"
          onClick={() => setIsOpen(false)}
        >
          <div
            className="bg-white rounded-2xl shadow-2xl w-[360px] max-w-[92vw] overflow-hidden"
            onClick={e => e.stopPropagation()}
            style={{ animation: 'helpSlideIn 0.35s cubic-bezier(0.34,1.56,0.64,1)' }}
          >
            {/* Header */}
            <div className="bg-gradient-to-r from-indigo-600 to-purple-600 px-5 py-4 text-white">
              <div className="flex items-center justify-between">
                <div>
                  <h3 className="font-bold text-lg leading-tight">{help.title}</h3>
                  <p className="text-indigo-200 text-xs mt-0.5">{help.subtitle}</p>
                </div>
                <button
                  onClick={() => setIsOpen(false)}
                  className="p-1 hover:bg-white/20 rounded-lg transition-colors"
                >
                  <svg className="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </button>
              </div>
              {/* Step indicators */}
              <div className="flex gap-1.5 mt-3">
                {help.steps.map((_, i) => (
                  <button
                    key={i}
                    onClick={() => setActiveStep(i)}
                    className={`h-1.5 rounded-full transition-all duration-300 ${
                      i === activeStep ? 'bg-white w-6' : 'bg-white/40 w-3 hover:bg-white/60'
                    }`}
                  />
                ))}
              </div>
            </div>

            {/* Step Content */}
            <div className="px-5 py-5">
              <div
                className={`transition-all duration-300 ${animating ? 'opacity-0 translate-y-2' : 'opacity-100 translate-y-0'}`}
              >
                <div className="flex items-start gap-3 mb-4">
                  <span className="text-3xl flex-shrink-0 mt-0.5" role="img">{help.steps[activeStep].icon}</span>
                  <div>
                    <h4 className="font-semibold text-gray-900 text-[15px]">{help.steps[activeStep].title}</h4>
                    <p className="text-gray-600 text-sm mt-1 leading-relaxed">{help.steps[activeStep].desc}</p>
                  </div>
                </div>

                {/* Step counter */}
                <p className="text-xs text-gray-400 text-center">
                  Step {activeStep + 1} of {help.steps.length}
                </p>
              </div>

              {/* Navigation */}
              <div className="flex items-center justify-between mt-4 pt-3 border-t border-gray-100">
                <button
                  onClick={prevStep}
                  disabled={activeStep === 0}
                  className="px-3 py-1.5 text-sm text-gray-600 hover:bg-gray-100 rounded-lg disabled:opacity-30 disabled:cursor-not-allowed transition-colors"
                >
                  ← Prev
                </button>
                {activeStep === help.steps.length - 1 ? (
                  <button
                    onClick={() => setIsOpen(false)}
                    className="px-4 py-1.5 text-sm bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors"
                  >
                    Got it ✓
                  </button>
                ) : (
                  <button
                    onClick={nextStep}
                    className="px-3 py-1.5 text-sm text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors font-medium"
                  >
                    Next →
                  </button>
                )}
              </div>
            </div>

            {/* Tips (if any) */}
            {help.tips && (
              <div className="px-5 pb-4">
                <div className="bg-amber-50 border border-amber-200 rounded-xl px-3 py-2.5">
                  <p className="text-xs font-semibold text-amber-700 mb-1">💡 Tips</p>
                  {help.tips.map((tip, i) => (
                    <p key={i} className="text-xs text-amber-600">• {tip}</p>
                  ))}
                </div>
              </div>
            )}
          </div>
        </div>
      )}

      {/* Keyframe animation */}
      <style>{`
        @keyframes helpSlideIn {
          from { opacity: 0; transform: translateY(-20px) scale(0.95); }
          to { opacity: 1; transform: translateY(0) scale(1); }
        }
      `}</style>
    </>
  );
}
